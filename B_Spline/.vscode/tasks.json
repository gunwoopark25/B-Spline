{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build B_Spline (cl.exe)",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/c",
                "\"C:\\Program Files\\Microsoft Visual Studio\\18\\Community\\VC\\Auxiliary\\Build\\vcvarsall.bat\" x64 && cl.exe /nologo /EHsc /Zi /std:c++20 /Fe:B_Spline.exe /Fo:.\\ main.cpp B_Spline.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "MSVC(cl.exe)로 main.cpp, B_Spline.cpp를 컴파일하여 B_Spline.exe 생성"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe 활성 파일 빌드",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/std:c++20",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${fileDirname}\\main.cpp",
                "${fileDirname}\\B_Spline.cpp"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "디버거에서 생성된 작업입니다."
        }
    ]
}